    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.53.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@trigger.dev/sdk": "4.4.6",
    "argon2": "^0.44.0",
