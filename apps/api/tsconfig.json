{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["esnext"],
    "types": ["node"],
    "rootDir": "../../",
    "outDir": "./dist",
    "paths": {
      "@alumni/shared": ["../../packages/shared/src/index.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*",
    "prisma.config.ts",
    "scripts/**/*",
    "trigger.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
