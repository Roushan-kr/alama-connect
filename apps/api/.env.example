# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=""

# ─── SERVER ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# ─── JWT SECRETS (generate with: node -e "require('crypto').randomBytes(64).toString('hex')" ) ──
JWT_SECRET=
JWT_REFRESH_SECRET=
EMAIL_SECRET=

# ─── REDIS (Upstash TCP) ─────────────────────────────────────────────────────
# Format: rediss://:<password>@<host>:<port>
REDIS_URL=

# ─── CLOUDFLARE R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=""
R2_PUBLIC_URL=
R2_TOKEN_VALUE=

# ─── EMAIL (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ─── TRIGGER.DEV ─────────────────────────────────────────────────────────────
TRIGGER_SECRET_KEY=

# ─── FRONTEND URL (for email deep-links) ────────────────────────────────────
WEB_URL=http://localhost:3000

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000