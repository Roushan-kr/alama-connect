# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/alumni_db"

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── AUTH ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-32-chars-minimum-random"
JWT_REFRESH_SECRET="change-me-32-chars-minimum-random-2"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── CLOUDFLARE R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="alumni-platform"
R2_PUBLIC_URL="https://cdn.yourdomain.com"

# ─── EMAIL (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
EMAIL_FROM="noreply@yourdomain.com"

# ─── TRIGGER.DEV ─────────────────────────────────────────────────────────────
TRIGGER_SECRET_KEY="tr_dev_xxxxxxxxxxxx"
TRIGGER_API_URL="https://api.trigger.dev"

# ─── SENTRY ──────────────────────────────────────────────────────────────────
SENTRY_DSN="https://xxxx@sentry.io/xxxx"

# ─── PUSH NOTIFICATIONS (FCM) ────────────────────────────────────────────────
FCM_PROJECT_ID="your-firebase-project-id"
FCM_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT="4000"
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"

# ─── VIRUS SCAN ──────────────────────────────────────────────────────────────
# Leave empty in dev — scan is stubbed to always pass
VIRUSTOTAL_API_KEY=""